diff --git a/lua/cn_en_spacer.lua b/lua/cn_en_spacer.lua
index 37771a0..fe5803b 100644
--- a/lua/cn_en_spacer.lua
+++ b/lua/cn_en_spacer.lua
@@ -21,7 +21,7 @@ end
 
 local function cn_en_spacer(input, env)
     for cand in input:iter() do
-        if is_mixed_cn_en_num(cand.text) then
+        if is_mixed_cn_en_num(cand.text) and env.engine.context:get_option("cn_en_space") then
             cand = cand:to_shadow_candidate(cand.type, add_spaces(cand.text), cand.comment)
         end
         yield(cand)
diff --git a/melt_eng.schema.yaml b/melt_eng.schema.yaml
index ba6d4e1..3c11ed1 100644
--- a/melt_eng.schema.yaml
+++ b/melt_eng.schema.yaml
@@ -16,6 +16,9 @@ schema:
   description: Easy English Nano，只包含少量常用词汇，方便中英文混合输入度方案调用。
 
 switches:
+  - name: cn_en_space
+    states: [ 中 A, 中A ]
+    abbrev: [ 密, 疏 ]
   - name: ascii_mode
     reset: 0
     states: [ASCII-OFF, ASCII-ON]
